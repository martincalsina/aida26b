{
  "name": "faculty-management-backend",
  "version": "1.0.0",
  "description": "Backend for Faculty Student Management System",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && cd ../frontend && npm run build",
    "build-backend": "tsc",
    "start": "node dist/backend/src/server.js",
    "dev": "ts-node src/server.ts",
    "watch": "nodemon --exec ts-node src/server.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/pg": "^8.10.2",
    "@types/cors": "^2.8.13",
    "@types/node": "^20.4.5",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1"
  }
}