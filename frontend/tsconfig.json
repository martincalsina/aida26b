{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "outDir": "./dist",
    "rootDir": "../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": ["src", "../shared/src"],
  "exclude": ["node_modules", "dist"]
}